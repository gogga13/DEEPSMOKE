DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=/home/username/your-domain/app/staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/home/username/your-domain/app/media
DJANGO_DB_ENGINE=mysql
MYSQL_DATABASE=deepsmoke
MYSQL_USER=cpanel_mysql_user
MYSQL_PASSWORD=strong-password
MYSQL_HOST=localhost
MYSQL_PORT=3306

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=yourgmail@gmail.com
EMAIL_FILE_PATH=/home/username/your-domain/runtime/sent_emails

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_TIMEOUT=5
NOVA_POSHTA_API_KEY=

SUPPORT_TELEGRAM_URL=
SUPPORT_INSTAGRAM_URL=
SUPPORT_PHONE=
